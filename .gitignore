# ===========================================================================
# OMNIX — .gitignore
# Organized by category. Keep this file tidy; do not add one-off scratch paths.
# ===========================================================================

# --- Runtime state (regenerated by `omnix analyze`; never tracked) ---------
.omnix/
*.db
*.db-journal
*.db-wal
*.db-shm
*-wal
*-shm
src/web/graph_data.json
src/web/timeline_data.json
*.gexf
# NOTE: src/web/graph_data_axiom_v2.json is intentionally NOT ignored — it is a
# load-bearing fixture imported by the Studio frontend (GraphCanvas.tsx and
# axiomFixture.ts). Do not add it here.

# --- Secrets (never commit under any circumstance) -------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secret.pem
public.pem

# --- Python build & packaging ----------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
.venv-*/
venv/

# --- Java (only the vendored .jar under src/omnix/semantic is checked in) ---
*.class

# --- Node ------------------------------------------------------------------
node_modules/

# --- Tooling caches & coverage ---------------------------------------------
.mypy_cache/
.pytest_cache/
.ruff_cache/
.hypothesis/
.coverage
coverage/
htmlcov/

# --- Editor / OS -----------------------------------------------------------
.DS_Store
.idea/
.vscode/

# --- Local AI-agent / developer tooling (never source of truth) ------------
.codex/
.claude/
.claude-flow/
.cursor/
.scratch/
.playwright-mcp/

# --- Review artifacts (bulk content dumps; never source) -------------------
*-full-contents.pdf
