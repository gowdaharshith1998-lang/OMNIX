# EditorConfig — https://editorconfig.org
# Top-level config for the OMNIX repository.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{js,ts,tsx,jsx,json,css,scss,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
