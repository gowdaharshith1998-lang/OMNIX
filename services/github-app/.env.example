# GitHub App configuration
APP_ID=
# Paste an escaped GitHub App PEM in your local .env only. Never commit it.
PRIVATE_KEY=
WEBHOOK_SECRET=

# OMNIX cloud backend (Shape A)
OMNIX_CLOUD_API_URL=http://localhost:8080
OMNIX_CLOUD_API_KEY=

# Stripe (Phase C2)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Server
PORT=3000
LOG_LEVEL=info

# Quota policy
FREE_TIER_REPOS_LIMIT=1
FREE_TIER_RUNS_PER_MONTH=5
TEAM_TIER_REPOS_LIMIT=10
